<?xml version="1.0"?>
<!--
  Phase 1 sedan URDF (case-B: PhysX rigid-body chassis + visual-only wheels).

  Design:
    - base_link: visual + collision box. Holds the full vehicle mass and
      the real-sedan-tuned inertia tensor (NOT the uniform-box value).
    - 4 cylinder wheels: VISUAL ONLY. <collision> deliberately omitted.
      Tire forces are computed in vehicle_rl.dynamics and injected as
      external force/torque on base_link (PLAN.md Phase 1.5).
    - Front wheels: steer joint (revolute Z) + spin joint (continuous Y)
    - Rear wheels:  spin joint only (continuous Y)
    - No suspension joints. Fz is computed analytically; ride height is
      enforced by the dynamics module.

  Frame convention (ROS URDF): x-forward, y-left, z-up.
  base_link origin = chassis CoG (z = 0.55 m above ground at static ride height).
  Wheel hub center at z = 0.33 m above ground (= wheel radius r).

  Vehicle parameters (PLAN.md):
    mass:      1500 kg (entirely in base_link; wheels are light dummies)
    inertia:   Ixx=500, Iyy=2500, Izz=2700 kg·m^2
                 (real-sedan tuned; uniform box would give 466/2592/2936)
    wheelbase: 2.7 m   (front axle x = +1.35, rear axle x = -1.35)
    track:     1.55 m  (left-right wheel y = +/-0.775)
    wheel:     r=0.33 m, width=0.225 m
    chassis:   4.5 x 1.8 x 0.7 m (visual + collision)
    steer:     +/-0.611 rad (~35 deg), effort 500 N·m, velocity 3 rad/s
-->
<robot name="sedan">

  <!-- =============== CHASSIS =============== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1500"/>
      <!--
        Real-sedan tuned inertia (PLAN.md). NOT uniform-box:
          uniform box (m=1500, 4.5x1.8x0.7) -> Ixx=466, Iyy=2592, Izz=2936
          real mid-size sedan target        -> Ixx=500, Iyy=2500, Izz=2700
        Visual/collision box geometry is for rendering and as a fall-through
        guard; mass distribution is set independently to match a real vehicle.
      -->
      <inertia ixx="500" ixy="0" ixz="0" iyy="2500" iyz="0" izz="2700"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="4.5 1.8 0.7"/></geometry>
      <material name="chassis_blue"><color rgba="0.2 0.4 0.8 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="4.5 1.8 0.7"/></geometry>
    </collision>
  </link>

  <!-- =============== FRONT LEFT (steer + spin) =============== -->
  <link name="front_left_steer">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="front_left_steer"/>
    <origin xyz="1.35 0.775 -0.22" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.611" upper="0.611" effort="500" velocity="3"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <!--
        Cylinder r=0.33, L=0.225 along link-Y (after rpy=1.5708,0,0), m=0.1:
          Iyy = 0.5*m*r^2          = 0.00545  (spin axis)
          Ixx = Izz = m/12*(3r^2 + L^2) = 0.00314
        Wheel mass kept tiny because total vehicle mass is in base_link.
        Phase 1.5 step 2 (Fiala / slip ratio) may revisit wheel inertia.
      -->
      <inertia ixx="0.00314" ixy="0" ixz="0" iyy="0.00545" iyz="0" izz="0.00314"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.33" length="0.225"/></geometry>
      <material name="wheel_black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <!-- NO <collision>: case-B uses analytic tire forces, not contact. -->
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer"/>
    <child  link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- =============== FRONT RIGHT (steer + spin) =============== -->
  <link name="front_right_steer">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="front_right_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="front_right_steer"/>
    <origin xyz="1.35 -0.775 -0.22" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.611" upper="0.611" effort="500" velocity="3"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00314" ixy="0" ixz="0" iyy="0.00545" iyz="0" izz="0.00314"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.33" length="0.225"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <!-- NO <collision>: case-B uses analytic tire forces. -->
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer"/>
    <child  link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- =============== REAR LEFT (spin only) =============== -->
  <link name="rear_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00314" ixy="0" ixz="0" iyy="0.00545" iyz="0" izz="0.00314"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.33" length="0.225"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <!-- NO <collision>: case-B uses analytic tire forces. -->
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_left_wheel"/>
    <origin xyz="-1.35 0.775 -0.22" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- =============== REAR RIGHT (spin only) =============== -->
  <link name="rear_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00314" ixy="0" ixz="0" iyy="0.00545" iyz="0" izz="0.00314"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.33" length="0.225"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <!-- NO <collision>: case-B uses analytic tire forces. -->
  </link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_right_wheel"/>
    <origin xyz="-1.35 -0.775 -0.22" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
